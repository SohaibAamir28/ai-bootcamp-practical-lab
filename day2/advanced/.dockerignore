# =============================================================================
# .dockerignore — Advanced
# Same as intermediate, but more thorough.
# =============================================================================

# SECRETS — never bake into the image
.env
*.key
*.pem
*.p12
secrets/
credentials/

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/

# Jupyter
notebooks/
*.ipynb
.ipynb_checkpoints/

# Version control
.git/
.gitignore
.gitattributes

# IDE
.vscode/
.idea/
*.swp
*.swo

# CI & docs (not needed at runtime)
.github/
*.md
tests/
docs/

# OS artifacts
.DS_Store
Thumbs.db
